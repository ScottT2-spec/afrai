# AfrAI Environment Configuration
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/afrai

# Redis
REDIS_URL=redis://localhost:6379

# Security
API_KEY_SALT=change-this-to-a-random-string-min-16-chars

# Provider API Keys (only set the ones you have)
GROQ_API_KEY=gsk_your_groq_key_here
SAMBANOVA_API_KEY=your_sambanova_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
OPENAI_API_KEY=sk-your_openai_key_here
GOOGLE_API_KEY=your_google_gemini_key_here

# Email Verification (Gmail SMTP)
SMTP_EMAIL=scottantwi930@gmail.com
SMTP_APP_PASSWORD=your_gmail_app_password_here

# Google OAuth2 (Continue with Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/v1/auth/google/callback
FRONTEND_URL=https://afrai.vercel.app
